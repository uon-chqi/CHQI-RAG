# ─────────────────────────────────────────────
# CHQI Health RAG System — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Database (PostgreSQL / Aiven) ──────────────
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require
# Or individual fields:
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-db-password
DB_SSL=true

# ── Authentication ─────────────────────────────
JWT_SECRET=chqi-health-secret-2026-change-in-production

# Super Admin (hard-coded credentials, not in DB)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=CHQIAdmin@2026
SUPER_ADMIN_EMAIL=admin@chqi.go.ke

# ── AI / RAG Services ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=your-index-name

# ── SMS / WhatsApp ─────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_ID=your-phone-id

# ── Server ─────────────────────────────────────
PORT=5000
NODE_ENV=development
